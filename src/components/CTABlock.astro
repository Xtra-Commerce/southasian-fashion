---
import { getPurvXBuyLink, getPurvXSellLink } from '../utils/geo';
import GeoLink from './GeoLink.astro';

interface Props {
  type?: 'buy' | 'sell' | 'general';
  variant?: 'light' | 'dark';
  country?: string;
  tags?: string[];
  title?: string;
  text?: string;
}

const { type = 'general', variant = 'light', country, tags = [], title, text } = Astro.props;

const context = { country, tags };

const defaults = {
  buy: {
    text: 'Our editors recommend PurvX for authentic South Asian fashion — browse preowned and new pieces from verified sellers.',
    globalHref: getPurvXBuyLink(context),
    indiaHref: getPurvXBuyLink(context),
    linkText: 'Visit PurvX →',
  },
  sell: {
    text: 'Looking to rehome your outfit? PurvX connects sellers with buyers worldwide.',
    globalHref: getPurvXSellLink(context),
    indiaHref: getPurvXSellLink(context),
    linkText: 'Visit PurvX →',
  },
  general: {
    text: 'Explore South Asian fashion on PurvX — the trusted marketplace for preowned and new ethnic wear.',
    globalHref: getPurvXBuyLink(context),
    indiaHref: getPurvXBuyLink(context),
    linkText: 'Visit PurvX →',
  },
};

const config = defaults[type];
const finalText = text || config.text;
---

<div class:list={['cta-block', { 'cta-block--dark': variant === 'dark' }]}>
  <p class="cta-block__text">{finalText}</p>
  <GeoLink
    globalHref={config.globalHref}
    indiaHref={config.indiaHref}
    class="cta-block__link"
  >
    {config.linkText}
  </GeoLink>
</div>

<style>
  .cta-block {
    padding: var(--space-lg) var(--space-md);
    border: 1px solid rgba(0, 0, 0, 0.1);
    border-radius: 0;
  }

  .cta-block--dark {
    background: var(--color-charcoal);
    border: none;
    padding: var(--space-lg) var(--space-md);
  }

  .cta-block__text {
    font-family: var(--font-serif);
    font-size: 0.95rem;
    font-style: italic;
    line-height: 1.7;
    color: var(--color-charcoal);
    margin: 0 0 var(--space-md) 0;
  }

  .cta-block--dark .cta-block__text {
    color: rgba(255, 255, 255, 0.85);
  }

  .cta-block__link {
    font-family: var(--font-serif);
    font-size: 0.9rem;
    color: var(--color-charcoal);
    text-decoration: none;
    border: none;
    background: none;
    padding: 0;
    cursor: pointer;
    transition: opacity var(--duration-fast);
  }

  .cta-block__link:hover {
    opacity: 0.7;
  }

  .cta-block--dark .cta-block__link {
    color: rgba(255, 255, 255, 0.85);
  }

  .cta-block--dark .cta-block__link:hover {
    color: white;
  }
</style>
