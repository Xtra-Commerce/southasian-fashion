---
import { getArticleCardImage } from '../utils/images';

interface Props {
  title: string;
  excerpt: string;
  category: string;
  slug: string;
  tags?: string[];
}

const { title, excerpt, category, slug, tags = [] } = Astro.props;

const categoryLabels: Record<string, string> = {
  'buy': 'Buying Guide',
  'sell': 'Selling Guide',
  'wedding': 'Wedding Guide',
  'learn': 'Culture & Style',
  'compare': 'Comparison',
};

const href = `/${category}/${slug}`;
const image = getArticleCardImage(slug, 600, 400);
---
<a href={href} class="article-card">
  <div class="article-card__image">
    <img src={image.url} alt={image.alt} loading="lazy" width="600" height="400" class="article-card__img" />
  </div>
  <div class="article-card__body">
    <span class="article-card__category">{categoryLabels[category] || category}</span>
    <h3 class="article-card__title">{title}</h3>
    <p class="article-card__excerpt">{excerpt}</p>
  </div>
</a>

<style>
  .article-card {
    display: block;
    background: white;
    overflow: hidden;
    text-decoration: none;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .article-card:hover {
    opacity: 1;
  }

  .article-card__image {
    aspect-ratio: 3/2;
    overflow: hidden;
    background: var(--color-cream);
    margin-bottom: var(--space-lg);
  }

  .article-card__img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: opacity var(--duration-normal) var(--ease-out);
    display: block;
  }

  .article-card:hover .article-card__img {
    opacity: 0.85;
  }

  .article-card__body {
    padding: 0;
  }

  .article-card__category {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-saffron);
    margin-bottom: var(--space-sm);
  }

  .article-card__title {
    font-family: var(--font-display);
    font-size: 1.35rem;
    font-weight: 400;
    line-height: 1.3;
    color: var(--color-charcoal);
    margin-bottom: var(--space-sm);
    letter-spacing: -0.01em;
  }

  .article-card__excerpt {
    font-size: 0.9rem;
    color: var(--color-text-secondary);
    line-height: 1.6;
    margin-bottom: 0;
    display: -webkit-box;
    -webkit-line-clamp: 3;
    -webkit-box-orient: vertical;
    overflow: hidden;
  }
</style>
