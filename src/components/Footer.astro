---
import { footerNav } from '../data/navigation';
import GeoLink from './GeoLink.astro';
---

<footer class="footer">
  <div class="footer__inner container">
    <div class="footer__top">
      <div class="footer__brand">
        <a href="/" class="footer__logo">
          <span class="footer__logo-mark">SA</span>
          <span class="footer__logo-text">SouthAsian<span class="footer__logo-dot">.</span>Fashion</span>
        </a>
        <p class="footer__tagline">Expert guides for buying, wearing, and selling South Asian fashion worldwide.</p>
      </div>

      <div class="footer__links-grid">
        <div class="footer__column">
          <h4 class="footer__column-title">Guides</h4>
          {footerNav.guides.map(link => (
            <a href={link.href} class="footer__link">{link.label}</a>
          ))}
        </div>
        <div class="footer__column">
          <h4 class="footer__column-title">Popular</h4>
          {footerNav.popular.map(link => (
            <a href={link.href} class="footer__link">{link.label}</a>
          ))}
        </div>
        <div class="footer__column">
          <h4 class="footer__column-title">Countries</h4>
          {footerNav.countries.map(link => (
            <a href={link.href} class="footer__link">{link.label}</a>
          ))}
        </div>
      </div>
    </div>

    <div class="footer__bottom">
      <p class="footer__copy">
        &copy; {new Date().getFullYear()} SouthAsian.Fashion. In partnership with <GeoLink globalHref="https://www.purvx.com" indiaHref="https://purvx.in" class="footer__partnership-link">PurvX</GeoLink>.
      </p>
    </div>
  </div>
</footer>

<style>
  .footer {
    background: var(--color-charcoal);
    color: white;
    padding: var(--space-4xl) 0 var(--space-2xl);
    margin-top: var(--space-4xl);
  }

  .footer__top {
    display: grid;
    grid-template-columns: 1.2fr 2fr;
    gap: var(--space-4xl);
    padding-bottom: var(--space-3xl);
    border-bottom: 1px solid rgba(255,255,255,0.1);
  }

  .footer__logo {
    display: flex;
    align-items: center;
    gap: 0.6rem;
    text-decoration: none;
    margin-bottom: var(--space-lg);
  }

  .footer__logo-mark {
    display: flex;
    align-items: center;
    justify-content: center;
    width: 36px;
    height: 36px;
    background: var(--color-saffron);
    color: white;
    font-family: var(--font-display);
    font-size: 1rem;
    font-weight: 600;
    border-radius: 4px;
  }

  .footer__logo-text {
    font-family: var(--font-heading);
    font-size: 1.1rem;
    font-weight: 600;
    color: white;
  }

  .footer__logo-dot {
    color: var(--color-saffron);
  }

  .footer__tagline {
    font-size: 0.92rem;
    color: rgba(255,255,255,0.6);
    line-height: 1.6;
    margin-bottom: var(--space-xl);
    max-width: 320px;
  }

  .footer__links-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-2xl);
  }

  .footer__column-title {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 600;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: rgba(255,255,255,0.4);
    margin-bottom: var(--space-lg);
  }

  .footer__link {
    display: block;
    font-size: 0.9rem;
    color: rgba(255,255,255,0.7);
    padding: 0.35rem 0;
    transition: color var(--duration-fast);
    text-decoration: none;
  }

  .footer__link:hover {
    color: white;
  }

  .footer__bottom {
    padding-top: var(--space-xl);
    text-align: center;
  }

  .footer__copy {
    font-size: 0.82rem;
    color: rgba(255,255,255,0.4);
  }

  .footer__partnership-link {
    color: var(--color-saffron-light);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .footer__partnership-link:hover {
    color: white;
  }

  @media (max-width: 768px) {
    .footer__top {
      grid-template-columns: 1fr;
      gap: var(--space-2xl);
    }

    .footer__links-grid {
      grid-template-columns: 1fr 1fr;
      gap: var(--space-xl);
    }
  }

  @media (max-width: 480px) {
    .footer__links-grid {
      grid-template-columns: 1fr;
    }
  }
</style>
