---
import { getPurvXSectionImages } from '../utils/images';
import { getPurvXLink } from '../utils/geo';

interface Props {
  sectionKey: string;
  title?: string;
  subtitle?: string;
  country?: string;
}

const { sectionKey, title = 'Shop on PurvX', subtitle, country } = Astro.props;
const items = getPurvXSectionImages(sectionKey);
const purvxBase = getPurvXLink({ country });
---
{items.length > 0 && (
  <section class="purvx-shop">
    <div class="purvx-shop__header">
      <span class="label">Shop Now</span>
      <h2 class="purvx-shop__title">{title}</h2>
      {subtitle && <p class="purvx-shop__subtitle">{subtitle}</p>}
    </div>
    <div class="purvx-shop__grid">
      {items.map(item => (
        <a href={item.link} target="_blank" rel="noopener" class="purvx-shop__card">
          <div class="purvx-shop__card-image">
            <img src={item.url} alt={item.title} loading="lazy" width="400" height="500" />
            <div class="purvx-shop__card-overlay">
              <span class="purvx-shop__card-cta">Shop now &rarr;</span>
            </div>
          </div>
          <p class="purvx-shop__card-title">{item.title}</p>
        </a>
      ))}
    </div>
    <div class="purvx-shop__footer">
      <a href={purvxBase} target="_blank" rel="noopener" class="btn btn--primary">
        Browse all on PurvX <span class="arrow">&rarr;</span>
      </a>
    </div>
  </section>
)}

<style>
  .purvx-shop {
    padding: var(--space-3xl) 0;
    margin: var(--space-2xl) 0;
  }

  .purvx-shop__header {
    text-align: center;
    margin-bottom: var(--space-2xl);
  }

  .purvx-shop__title {
    font-family: var(--font-display);
    font-size: clamp(1.5rem, 3vw, 2.25rem);
    font-weight: 400;
    color: var(--color-charcoal);
    margin-top: var(--space-sm);
  }

  .purvx-shop__subtitle {
    font-size: 1rem;
    color: var(--color-text-secondary);
    margin-top: var(--space-sm);
    max-width: 500px;
    margin-left: auto;
    margin-right: auto;
  }

  .purvx-shop__grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: var(--space-lg);
  }

  .purvx-shop__card {
    display: block;
    text-decoration: none;
    transition: transform var(--duration-normal) var(--ease-out);
  }

  .purvx-shop__card:hover {
    transform: translateY(-4px);
  }

  .purvx-shop__card-image {
    position: relative;
    aspect-ratio: 4/5;
    border-radius: var(--radius-lg);
    overflow: hidden;
    background: var(--color-cream);
  }

  .purvx-shop__card-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    transition: transform 0.5s var(--ease-out);
  }

  .purvx-shop__card:hover .purvx-shop__card-image img {
    transform: scale(1.05);
  }

  .purvx-shop__card-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(180deg, transparent 50%, rgba(42,37,32,0.6) 100%);
    display: flex;
    align-items: flex-end;
    justify-content: center;
    padding: var(--space-lg);
    opacity: 0;
    transition: opacity var(--duration-normal) var(--ease-out);
  }

  .purvx-shop__card:hover .purvx-shop__card-overlay {
    opacity: 1;
  }

  .purvx-shop__card-cta {
    font-family: var(--font-heading);
    font-size: 0.85rem;
    font-weight: 600;
    color: white;
    letter-spacing: 0.05em;
  }

  .purvx-shop__card-title {
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 600;
    color: var(--color-charcoal);
    text-align: center;
    margin-top: var(--space-md);
  }

  .purvx-shop__footer {
    text-align: center;
    margin-top: var(--space-2xl);
  }

  @media (max-width: 768px) {
    .purvx-shop__grid {
      grid-template-columns: repeat(2, 1fr);
    }
  }

  @media (max-width: 480px) {
    .purvx-shop__grid {
      grid-template-columns: 1fr;
      max-width: 300px;
      margin: 0 auto;
    }
  }
</style>
