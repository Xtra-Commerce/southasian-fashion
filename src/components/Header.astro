---
import { mainNav } from '../data/navigation';
---
<header class="header">
  <div class="header__inner">
    <!-- Masthead -->
    <a href="/" class="header__masthead">
      SOUTH ASIAN FASHION
    </a>

    <!-- Desktop Navigation -->
    <nav class="header__nav hide-mobile" aria-label="Main navigation">
      {mainNav.map(item => (
        <a href={item.href} class="header__nav-link">{item.label.split(' ')[0]}</a>
      ))}
      <a href="https://www.purvx.com/s" class="header__nav-link header__nav-link--shop" target="_blank" rel="noopener">
        Shop
      </a>
    </nav>

    <!-- Mobile Menu Button -->
    <button class="header__menu-btn hide-desktop" aria-label="Open menu" id="menuToggle">
      <span></span><span></span><span></span>
    </button>
  </div>

  <!-- Mobile Menu -->
  <div class="header__mobile-menu" id="mobileMenu">
    <nav class="header__mobile-nav">
      {mainNav.map(item => (
        <a href={item.href} class="header__mobile-link">{item.label}</a>
      ))}
      <a href="https://www.purvx.com/s" class="header__mobile-link header__mobile-link--shop" target="_blank" rel="noopener">
        Shop
      </a>
    </nav>
  </div>
</header>

<style>
  .header {
    position: sticky;
    top: 0;
    z-index: 100;
    background: white;
    border-bottom: 1px solid #e5e5e5;
  }

  .header__inner {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 1.5rem var(--gutter);
    max-width: var(--max-width-wide);
    margin: 0 auto;
  }

  /* Masthead - Magazine nameplate style */
  .header__masthead {
    font-family: 'Cormorant Garamond', serif;
    font-size: 1.3rem;
    font-weight: 400;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--color-charcoal);
    text-decoration: none;
    line-height: 1;
    flex-shrink: 0;
  }

  .header__masthead:hover {
    color: var(--color-deep-burgundy);
  }

  /* Desktop Navigation */
  .header__nav {
    display: flex;
    align-items: center;
    gap: 2.5rem;
    margin-left: auto;
  }

  .header__nav-link {
    font-family: var(--font-heading);
    font-size: 0.75rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .header__nav-link:hover {
    color: var(--color-charcoal);
  }

  .header__nav-link--shop {
    color: var(--color-saffron);
  }

  .header__nav-link--shop:hover {
    color: var(--color-deep-burgundy);
  }

  /* Mobile Menu Button */
  .header__menu-btn {
    display: flex;
    flex-direction: column;
    gap: 5px;
    background: none;
    border: none;
    cursor: pointer;
    padding: 4px;
    margin-left: 1.5rem;
  }

  .header__menu-btn span {
    display: block;
    width: 20px;
    height: 1.5px;
    background: var(--color-charcoal);
    transition: all var(--duration-normal) var(--ease-out);
  }

  /* Mobile Menu */
  .header__mobile-menu {
    display: none;
    position: fixed;
    top: 100%;
    left: 0;
    right: 0;
    bottom: 0;
    background: white;
    z-index: 99;
    overflow-y: auto;
    padding: var(--space-xl) var(--gutter);
    border-top: 1px solid #e5e5e5;
  }

  .header__mobile-menu.is-open {
    display: block;
  }

  .header__mobile-nav {
    display: flex;
    flex-direction: column;
    gap: var(--space-lg);
  }

  .header__mobile-link {
    display: block;
    font-family: var(--font-heading);
    font-size: 0.95rem;
    font-weight: 500;
    color: var(--color-text-secondary);
    text-decoration: none;
    transition: color var(--duration-fast);
  }

  .header__mobile-link:hover {
    color: var(--color-charcoal);
  }

  .header__mobile-link--shop {
    color: var(--color-saffron);
  }

  .header__mobile-link--shop:hover {
    color: var(--color-deep-burgundy);
  }

  /* Responsive adjustments */
  @media (max-width: 768px) {
    .header__inner {
      padding: 1rem var(--gutter);
    }

    .header__masthead {
      font-size: 1rem;
      letter-spacing: 0.12em;
    }
  }
</style>

<script is:inline>
  document.getElementById('menuToggle')?.addEventListener('click', function() {
    document.getElementById('mobileMenu')?.classList.toggle('is-open');
  });
</script>
