---
// Renders a visual image break within article prose
// Used to break up text-heavy articles with contextual imagery

interface ImageItem {
  url: string;
  alt: string;
  caption?: string;
}

interface Props {
  images: ImageItem[];
  layout?: 'single' | 'duo' | 'trio';
}

const { images, layout = images.length >= 3 ? 'trio' : images.length === 2 ? 'duo' : 'single' } = Astro.props;
---
<figure class:list={['article-images', `article-images--${layout}`]}>
  {images.map(img => (
    <div class="article-images__item">
      <img src={img.url} alt={img.alt} loading="lazy" width="800" height="600" />
      {img.caption && <figcaption class="article-images__caption">{img.caption}</figcaption>}
    </div>
  ))}
</figure>

<style>
  .article-images {
    margin: var(--space-2xl) calc(-1 * var(--space-lg));
    padding: 0;
    display: grid;
    gap: var(--space-sm);
    border-radius: var(--radius-lg);
    overflow: hidden;
  }

  .article-images--single {
    grid-template-columns: 1fr;
  }

  .article-images--duo {
    grid-template-columns: 1fr 1fr;
  }

  .article-images--trio {
    grid-template-columns: 1fr 1fr 1fr;
  }

  .article-images__item {
    overflow: hidden;
    position: relative;
  }

  .article-images__item img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
    aspect-ratio: 4/3;
    transition: transform 0.5s var(--ease-out);
  }

  .article-images--single .article-images__item img {
    aspect-ratio: 16/9;
    max-height: 480px;
  }

  .article-images__item:hover img {
    transform: scale(1.03);
  }

  .article-images__caption {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-md) var(--space-lg);
    background: linear-gradient(transparent, rgba(42,37,32,0.7));
    color: rgba(255,255,255,0.9);
    font-size: 0.82rem;
    line-height: 1.5;
    font-style: italic;
  }

  @media (max-width: 768px) {
    .article-images {
      margin-left: 0;
      margin-right: 0;
    }

    .article-images--trio {
      grid-template-columns: 1fr;
    }

    .article-images--duo {
      grid-template-columns: 1fr;
    }
  }
</style>
