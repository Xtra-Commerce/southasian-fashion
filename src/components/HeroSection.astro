---
interface Props {
  title: string;
  subtitle?: string;
  label?: string;
  size?: 'large' | 'medium' | 'small';
}

const { title, subtitle, label, size = 'medium' } = Astro.props;
---
<section class:list={['hero', `hero--${size}`]}>
  <div class="hero__inner container">
    {label && <span class="hero__label label">{label}</span>}
    <h1 class:list={['hero__title', size === 'large' ? 'display-xl' : 'display-lg']}>{title}</h1>
    {subtitle && <p class="hero__subtitle">{subtitle}</p>}
    <slot />
  </div>
  <div class="hero__ornament">
    <span class="ornament--double"></span>
  </div>
</section>

<style>
  .hero {
    position: relative;
    padding: var(--space-4xl) 0 var(--space-3xl);
    text-align: center;
    background: linear-gradient(180deg, var(--color-ivory) 0%, var(--color-warm-white) 100%);
  }

  .hero--large {
    padding: var(--space-5xl) 0 var(--space-4xl);
  }

  .hero--small {
    padding: var(--space-2xl) 0 var(--space-xl);
  }

  .hero__inner {
    max-width: 860px;
  }

  .hero__label {
    display: inline-block;
    margin-bottom: var(--space-lg);
  }

  .hero__title {
    margin-bottom: var(--space-lg);
  }

  .hero__subtitle {
    font-size: clamp(1rem, 2vw, 1.2rem);
    color: var(--color-text-secondary);
    max-width: 640px;
    margin: 0 auto;
    line-height: 1.7;
  }

  .hero__ornament {
    display: flex;
    justify-content: center;
    margin-top: var(--space-2xl);
  }
</style>
