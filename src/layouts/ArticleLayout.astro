---
import BaseLayout from './BaseLayout.astro';
import FAQSection from '../components/FAQSection.astro';
import RelatedArticles from '../components/RelatedArticles.astro';
import InlineArticleImages from '../components/InlineArticleImages.astro';
import PurvXListings from '../components/PurvXListings.astro';
import { generateArticleSchema } from '../utils/schema';
import { getArticleHeroImage, getArticleInlineImages } from '../utils/images';
import { getCollection } from 'astro:content';

interface Props {
  frontmatter: {
    title: string;
    description: string;
    category: string;
    tags: string[];
    country?: string;
    publishDate: string;
    updatedDate?: string;
  };
  faqs?: { question: string; answer: string }[];
}

const { frontmatter, faqs = [] } = Astro.props;

const categoryLabels: Record<string, string> = {
  'buy': 'Buying Guide',
  'sell': 'Selling Guide',
  'wedding': 'Wedding Guide',
  'learn': 'Culture & Style',
  'compare': 'Comparison',
};

const slug = Astro.url.pathname.split('/').filter(Boolean).pop() || '';

const schema = generateArticleSchema({
  title: frontmatter.title,
  description: frontmatter.description,
  slug,
  category: frontmatter.category,
  publishDate: frontmatter.publishDate,
  updatedDate: frontmatter.updatedDate,
  tags: frontmatter.tags,
});

const heroImage = getArticleHeroImage(slug, 1200, 600);
const inlineImageGroups = getArticleInlineImages(slug);

// Determine PurvX shop section to show based on article category/tags
const shopSectionKey = frontmatter.category === 'wedding' ? 'wedding' :
  frontmatter.tags?.some((t: string) => t.includes('lehenga')) ? 'lehenga' :
  frontmatter.tags?.some((t: string) => t.includes('saree')) ? 'saree' :
  frontmatter.tags?.some((t: string) => ['sherwani', 'kurta', 'men'].some(k => t.includes(k))) ? 'mens' :
  frontmatter.category === 'buy' || frontmatter.category === 'compare' ? 'saree' :
  null;

// Get related articles
const allCollections = await Promise.all([
  getCollection('buy'),
  getCollection('sell'),
  getCollection('wedding'),
  getCollection('learn'),
  getCollection('compare'),
]);

const allArticles = allCollections.flat().filter(a => !a.data.draft);

const currentTags = frontmatter.tags || [];
const related = allArticles
  .filter(a => a.id !== slug)
  .map(a => {
    let score = 0;
    if (a.data.category === frontmatter.category) score += 2;
    const commonTags = (a.data.tags || []).filter((t: string) => currentTags.includes(t));
    score += commonTags.length * 1.5;
    return { article: a, score };
  })
  .filter(({ score }) => score > 0)
  .sort((a, b) => b.score - a.score)
  .slice(0, 4)
  .map(({ article }) => ({
    slug: article.id,
    title: article.data.title,
    excerpt: article.data.description,
    category: article.data.category,
    tags: article.data.tags,
  }));

// Calculate reading time (approximate)
const readingTime = Math.ceil((frontmatter.description.split(' ').length || 0) / 200);
---
<BaseLayout title={frontmatter.title} description={frontmatter.description} schema={schema}>
  <article class="article">
    {/* Hero Section with Full-Width Image and Overlay */}
    <section class="article__hero">
      <div class="article__hero-image">
        <img src={heroImage.url} alt={heroImage.alt} width="1200" height="600" loading="eager" />
        <div class="article__hero-overlay"></div>
      </div>
      <div class="article__hero-content">
        <span class="article__category-label">{categoryLabels[frontmatter.category]}</span>
        <h1 class="article__title">{frontmatter.title}</h1>
        <div class="article__meta">
          <time datetime={frontmatter.publishDate}>
            {new Date(frontmatter.publishDate).toLocaleDateString('en-US', { year: 'numeric', month: 'long', day: 'numeric' })}
          </time>
          <span class="article__meta-separator">•</span>
          <span class="article__reading-time">{readingTime} min read</span>
        </div>
      </div>
    </section>

    {/* Main Content */}
    <div class="article__body">
      <div class="article__content">
        {/* First image group — before the content starts */}
        {inlineImageGroups.length > 0 && (
          <InlineArticleImages images={inlineImageGroups[0]} />
        )}

        <div class="prose">
          <slot />
        </div>

        {/* Second image group — after the prose */}
        {inlineImageGroups.length > 1 && (
          <InlineArticleImages images={inlineImageGroups[1]} />
        )}

        {/* Third image group — if available */}
        {inlineImageGroups.length > 2 && (
          <InlineArticleImages images={inlineImageGroups[2]} />
        )}
      </div>
    </div>

    {/* PurvX Shop Section */}
    {shopSectionKey && (
      <section class="article__shop">
        <PurvXListings shopCategory={shopSectionKey} />
      </section>
    )}

    {/* FAQ Section */}
    {faqs.length > 0 && (
      <section class="article__faqs">
        <FAQSection faqs={faqs} />
      </section>
    )}

    {/* Related Articles */}
    {related.length > 0 && (
      <section class="article__related">
        <RelatedArticles articles={related} />
      </section>
    )}

    {/* Subtle End CTA */}
    <div class="article__end-cta">
      <a href="/shop" class="article__cta-link">Continue Shopping on PurvX <span class="article__cta-arrow">→</span></a>
    </div>
  </article>
</BaseLayout>

<style>
  .article {
    padding-bottom: var(--space-4xl);
  }

  /* Hero Section */
  .article__hero {
    position: relative;
    margin-bottom: var(--space-4xl);
  }

  .article__hero-image {
    width: 100%;
    height: 60vh;
    max-height: 600px;
    overflow: hidden;
    position: relative;
  }

  .article__hero-image img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    display: block;
  }

  .article__hero-overlay {
    position: absolute;
    inset: 0;
    background: linear-gradient(to bottom, rgba(0, 0, 0, 0.3) 0%, rgba(0, 0, 0, 0.5) 100%);
    z-index: 1;
  }

  .article__hero-content {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: var(--space-3xl) var(--space-lg);
    z-index: 2;
    color: white;
    text-shadow: 0 2px 10px rgba(0, 0, 0, 0.3);
  }

  @media (max-width: 768px) {
    .article__hero-image {
      height: 40vh;
    }

    .article__hero-content {
      padding: var(--space-2xl) var(--space-lg);
    }
  }

  .article__category-label {
    display: inline-block;
    font-family: var(--font-heading);
    font-size: 0.65rem;
    font-weight: 600;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: rgba(255, 255, 255, 0.9);
    margin-bottom: var(--space-sm);
  }

  .article__title {
    font-family: var(--font-display);
    font-size: clamp(2.5rem, 7vw, 4rem);
    font-weight: 400;
    line-height: 1.1;
    margin-bottom: var(--space-md);
    color: white;
    letter-spacing: -0.02em;
  }

  .article__meta {
    display: flex;
    align-items: center;
    gap: var(--space-sm);
    font-size: 0.95rem;
    color: rgba(255, 255, 255, 0.85);
  }

  .article__meta-separator {
    opacity: 0.6;
  }

  .article__reading-time {
    font-style: italic;
  }

  /* Main Content */
  .article__body {
    display: flex;
    justify-content: center;
    margin-bottom: var(--space-4xl);
  }

  .article__content {
    width: 100%;
    max-width: 750px;
    padding: 0 var(--space-lg);
  }

  /* Prose Styling */
  .prose {
    font-size: 1.1rem;
    line-height: 1.8;
    color: var(--color-text);
    margin-bottom: var(--space-3xl);
  }

  .prose :global(> *) {
    margin-bottom: var(--space-lg);
  }

  .prose :global(p:first-of-type::first-letter) {
    font-size: 3.2em;
    font-weight: 400;
    float: left;
    line-height: 1;
    margin-right: 0.1em;
    margin-top: 0.1em;
    font-family: var(--font-display);
    color: var(--color-charcoal);
  }

  .prose :global(h2) {
    font-family: var(--font-display);
    font-size: 1.8rem;
    font-weight: 400;
    margin-top: var(--space-3xl);
    margin-bottom: var(--space-lg);
    color: var(--color-charcoal);
    line-height: 1.3;
  }

  .prose :global(h3) {
    font-family: var(--font-display);
    font-size: 1.4rem;
    font-weight: 400;
    margin-top: var(--space-2xl);
    margin-bottom: var(--space-md);
    color: var(--color-charcoal);
  }

  .prose :global(a) {
    color: var(--color-saffron);
    text-decoration: underline;
    transition: opacity var(--duration-normal);
  }

  .prose :global(a:hover) {
    opacity: 0.8;
  }

  /* Inline Images */
  .prose :global(.inline-article-images) {
    margin: var(--space-3xl) 0;
  }

  /* Shop Section */
  .article__shop {
    margin: var(--space-4xl) 0;
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--color-border-light);
    border-bottom: 1px solid var(--color-border-light);
  }

  /* FAQ Section */
  .article__faqs {
    margin: var(--space-4xl) 0;
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--color-border-light);
  }

  /* Related Articles */
  .article__related {
    margin: var(--space-4xl) 0;
    padding-top: var(--space-3xl);
    border-top: 1px solid var(--color-border-light);
  }

  /* End CTA */
  .article__end-cta {
    text-align: center;
    padding: var(--space-3xl) 0;
    border-top: 1px solid var(--color-border-light);
  }

  .article__cta-link {
    font-family: var(--font-heading);
    font-size: 1rem;
    font-weight: 500;
    color: var(--color-charcoal);
    text-decoration: none;
    letter-spacing: 0.02em;
    transition: opacity var(--duration-normal);
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
  }

  .article__cta-link:hover {
    opacity: 0.7;
  }

  .article__cta-arrow {
    transition: transform var(--duration-normal);
    display: inline-block;
  }

  .article__cta-link:hover .article__cta-arrow {
    transform: translateX(4px);
  }
</style>
