---
import BaseLayout from '../layouts/BaseLayout.astro';
import HeroSection from '../components/HeroSection.astro';
import ArticleCard from '../components/ArticleCard.astro';
import CTABlock from '../components/CTABlock.astro';
import Breadcrumbs from '../components/Breadcrumbs.astro';
import { getCategoryHeroImage } from '../utils/images';
import { getCollection } from 'astro:content';

const articles = (await getCollection('sell'))
  .filter(a => !a.data.draft)
  .sort((a, b) => new Date(b.data.publishDate).getTime() - new Date(a.data.publishDate).getTime());

const heroImage = getCategoryHeroImage('sell');
---
<BaseLayout
  title="Selling Guides — Sell South Asian Outfits Online"
  description="Learn how to sell your South Asian outfits online. Pricing guides, platform comparisons, photography tips, and strategies to maximize resale value."
>
  <div class="container">
    <Breadcrumbs items={[{ name: 'Selling Guides', url: '/selling' }]} />
  </div>

  <HeroSection
    title="Sell Your South Asian Outfits"
    subtitle="Your lehenga, saree, or sherwani deserves a second life. Learn how to price, photograph, list, and sell your outfits for the best return."
    label="Selling Guides"
    size="medium"
    backgroundImage={heroImage.url}
    backgroundAlt={heroImage.alt}
  />

  <section class="section">
    <div class="container">
      {articles.length > 0 ? (
        <div class="grid grid--3">
          {articles.map(article => (
            <ArticleCard
              title={article.data.title}
              excerpt={article.data.description}
              category={article.data.category}
              slug={article.id}
              tags={article.data.tags}
            />
          ))}
        </div>
      ) : (
        <p style="text-align:center;color:var(--color-text-light);padding:var(--space-3xl) 0;">Selling guides coming soon.</p>
      )}

      <div style="margin-top:var(--space-3xl);">
        <CTABlock type="sell" variant="dark" />
      </div>
    </div>
  </section>
</BaseLayout>
